{
  "cSpell.caseSensitive": false,
  "cSpell.enabledFileTypes": {
    "css": true,
    "html": true,
    "javascript": true,
    "javascriptreact": true,
    "markdown": true,
    "plaintext": true,
    "shellscript": true,
    "sql": true,
    "text": true,
    "typescript": true,
    "typescriptreact": true,
    "yaml": true
  },
  "cSpell.language": "en-US",
  "cSpell.overrides": [
    {
      "filename": "**/*.{markdown,md,tex,txt}",
      "caseSensitive": true,
      "language": "en-GB"
    }
  ],
  "cSpell.words": [
    "amannn",
    "autoincrement",
    "blocklist",
    "blocklisted",
    "blurple",
    "Caddyfile",
    "Cherrys",
    "colorjs",
    "COMPSCI",
    "COMPSYS",
    "cooldown",
    "Dango",
    "dbname",
    "desaturate",
    "dotenv",
    "ECSE",
    "ELECTENG",
    "ENGGEN",
    "Greyple",
    "Grogu",
    "hypesquad",
    "isready",
    "Jeffers",
    "laggy",
    "leaderboard",
    "luxon",
    "Makaurau",
    "MERN",
    "nextjs",
    "nonexistent",
    "nums",
    "PGDATABASE",
    "PGHOST",
    "PGPASSWORD",
    "PGPORT",
    "PGUSER",
    "plpgsql",
    "pngjs",
    "psql",
    "rgba",
    "ROWTYPE",
    "SAVEPOINT",
    "setval",
    "skibidi",
    "slnt",
    "SOFTENG",
    "Spinjitzu",
    "Tāmaki",
    "Tatsu",
    "Taumata",
    "timestamptz",
    "trackpads",
    "tzdata",
    "unassigns",
    "upserts",
    "Waipapa",
    "WCAG",
    "wdth",
    "wght",
    "wordmark",
    "xmloption"
  ],
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "explicit"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "eslint.format.enable": true,
  "files.trimFinalNewlines": true,
  "files.trimTrailingWhitespace": true,
  "markdownlint.config": {
    "first-line-heading": false,
    "no-hard-tabs": false,
    "no-inline-html": false,
    "no-trailing-punctuation": false
  },
  "search.exclude": {
    "**/.next": true,
    "**/build": true,
    "**/dist": true,
    "**/node_modules": true
  },
  "[prisma]": {
    "editor.defaultFormatter": "Prisma.prisma"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  }
}
