{
  "name": "@blurple-canvas-web/backend",
  "description": "API server for Blurple Canvas",
  "version": "0.1.0",
  "private": true,
  "contributors": [
    "Aaron Guo <aaronjoshguo@gmail.com>",
    "Emily Zou <yzou415@aucklanduni.ac.nz>",
    "Henry Wang <hwan513@aucklanduni.ac.nz> (http://henryh.wang)",
    "Jasper Lai <klai866@aucklanduni.ac.nz> (https://lai.nz)",
    "Josh Jeffers <joshjeffers600@gmail.com> (https://pumbas.net)",
    "Samuel Ou <me@sjou.dev> (https://sjou.dev)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/project-blurple/Canvas-Web.git",
    "directory": "packages/backend"
  },
  "license": "SEE LICENSE IN LICENSE.md",
  "bugs": {
    "url": "https://github.com/project-blurple/Canvas-Web/issues"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.json",
    "dev": "nodemon src/index.ts --devmode",
    "start": "node build/index.js",
    "postinstall": "prisma generate",
    "test": "vitest",
    "format": "prettier --check --cache . --ignore-path ../../.gitignore",
    "format:fix": "prettier --write --cache . --ignore-path ../../.gitignore",
    "lint": "biome check --formatter-enabled=false .",
    "lint:fix": "biome check --formatter-enabled=false --write .",
    "check": "pnpm format && pnpm lint",
    "check:fix": "pnpm format:fix && pnpm lint:fix",
    "clean": "rm -rf node_modules/ build/"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@quixo3/prisma-session-store": "^3.1.19",
    "@types/express-session": "^1.18.2",
    "@types/passport": "^1.0.17",
    "@types/passport-discord": "^0.1.15",
    "@types/pngjs": "^6.0.5",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "pngjs": "^7.0.0",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@blurple-canvas-web/types": "workspace:*",
    "@tsconfig/node24": "^24.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.1.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prisma": "^5.22.0",
    "prismock": "^1.35.4",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  }
}
